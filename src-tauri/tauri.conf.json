{
  "$schema": "https://raw.githubusercontent.com/nickkuk/nickkuk.github.io/main/src/schemas/tauri-2-schema.json",
  "productName": "ShotAsk",
  "version": "1.0.0",
  "identifier": "com.shotask.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ShotAsk",
        "width": 520,
        "height": 680,
        "center": true,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": true,
        "url": "/"
      },
      {
        "label": "overlay",
        "title": "",
        "width": 1920,
        "height": 1080,
        "center": false,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "url": "/overlay.html"
      },
      {
        "label": "result",
        "title": "ShotAsk",
        "width": 440,
        "height": 360,
        "center": false,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "url": "/result.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
